{
  "expo": {
    "name": "Bible Wake",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FAFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tinochiwara.biblewake",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      },
      "associatedDomains": ["applinks:cmaysraaclfvofiynctl.supabase.co"]
    },
    "android": {
      "package": "com.tinochiwara.biblewake"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A73E8"
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
