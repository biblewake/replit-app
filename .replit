modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "artifacts/api-server: API Server"

[[workflows.workflow]]
name = "artifacts/mobile: expo"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/mobile"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mobile run dev"
cwd = "./artifacts/mobile"
waitForPort = 18115
ensurePreviewReachable = "/status"
router = "expo-domain"

[workflows.workflow.tasks.env]
PORT = "18115"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "3B4_FFSkEVBkAeYMFRJ2e"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
cwd = "./artifacts/api-server"
waitForPort = 8080

[workflows.workflow.tasks.env]
PORT = "8080"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"

[[workflows.workflow]]
name = "Sentry"
mode = "sequential"
author = 59918954

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mobile"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "eas env:create --scope project --name EXPO_PUBLIC_SENTRY_DSN --value https://e7a992aea17135255db530c816a5bd8a@o4511542532636672.ingest.de.sentry.io/4511542546071632"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_qcQGimcSliuPMLsUowIUaXVkXWH"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_AkFfviISpWttxOuYlHLhuSkKaTl"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_lLalAJHTQxacdOHxOdXiJoeHWJo"
REVENUECAT_PROJECT_ID = "proj4b4ff689"
REVENUECAT_TEST_STORE_APP_ID = "app8576dab305"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appde341465fd"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app03aa2a6a79"
EXPO_PUBLIC_SUPABASE_URL = "https://cmaysraaclfvofiynctl.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY = "sb_publishable_8TV1RczxgWVusyqdaJeaNg_Ayi1x6lD"

[nix]
channel = "stable-25_05"
