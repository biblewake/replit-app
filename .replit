modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18115
externalPort = 80

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_qcQGimcSliuPMLsUowIUaXVkXWH"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_AkFfviISpWttxOuYlHLhuSkKaTl"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_lLalAJHTQxacdOHxOdXiJoeHWJo"
REVENUECAT_PROJECT_ID = "proj4b4ff689"
REVENUECAT_TEST_STORE_APP_ID = "app8576dab305"
REVENUECAT_APPLE_APP_STORE_APP_ID = "appde341465fd"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app03aa2a6a79"

[nix]
channel = "stable-25_05"
